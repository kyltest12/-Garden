PORT=3000
JWT_SECRET=replace-with-a-long-random-secret

# ID из ссылки на Google Таблицу. Можно оставить пустым — сервер создаст таблицу при старте.
GOOGLE_SHEET_ID=

# Вариант 1: файл ключа service account
GOOGLE_APPLICATION_CREDENTIALS=./your-service-account.json

# Вариант 2: отдельные поля (вместо файла)
# GOOGLE_SERVICE_ACCOUNT_EMAIL=your-account@project.iam.gserviceaccount.com
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
